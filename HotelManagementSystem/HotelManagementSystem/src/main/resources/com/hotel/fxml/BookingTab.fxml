<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.BookingController"
      style="-fx-background-color: #121212; -fx-padding: 24;">

    <!-- ── New Booking ───────────────────────── -->
    <VBox spacing="16"
          style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">

        <Label text="New Booking"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <GridPane hgap="16" vgap="12">

            <columnConstraints>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 0 -->
            <Label text="Customer"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="0"/>

            <ComboBox fx:id="customerCombo"
                      maxWidth="Infinity"
                      style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0"/>

            <Label text="Available Room"
                   style="-fx-text-fill: white;"
                   GridPane.columnIndex="2"
                   GridPane.rowIndex="0"/>

            <ComboBox fx:id="roomCombo"
                      maxWidth="Infinity"
                      style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                      GridPane.columnIndex="3"
                      GridPane.rowIndex="0"/>

            <!-- Row 1 -->
            <Label text="Check-in Date"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="1"/>

            <DatePicker fx:id="checkInPicker"
                        maxWidth="Infinity"
                        promptText="Select check-in date"
                        style="-fx-background-color: #1e1e1e;"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="1"/>

            <Label text="Check-out Date"
                   style="-fx-text-fill: white;"
                   GridPane.columnIndex="2"
                   GridPane.rowIndex="1"/>

            <DatePicker fx:id="checkOutPicker"
                        maxWidth="Infinity"
                        promptText="Select check-out date"
                        style="-fx-background-color: #1e1e1e;"
                        GridPane.columnIndex="3"
                        GridPane.rowIndex="1"/>

        </GridPane>

        <!-- Birthday Discount -->
        <Label fx:id="birthdayLabel"
               text=""
               style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"/>

        <HBox spacing="12">
            <Button text="📋 Book Room"
                    onAction="#handleBook"
                    style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>

            <Button text="↺ Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: transparent; -fx-border-color: #c6a75e; -fx-text-fill: #c6a75e;"/>
        </HBox>

    </VBox>

    <!-- ── Booking History ───────────────────────── -->
    <Label text="Booking History"
           style="-fx-text-fill: white; -fx-font-size: 16px;"/>

    <TableView fx:id="bookingTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #1c1c1c;">

        <columns>
            <TableColumn fx:id="colBookingId" text="Booking ID"/>
            <TableColumn fx:id="colCustomerName" text="Customer"/>
            <TableColumn fx:id="colRoomNumber" text="Room"/>
            <TableColumn fx:id="colCheckIn" text="Check-in"/>
            <TableColumn fx:id="colCheckOut" text="Check-out"/>
            <TableColumn fx:id="colPackageName" text="Package"/>
            <TableColumn fx:id="colStatus" text="Status"/>
        </columns>

        <placeholder>
            <Label text="No bookings yet."
                   style="-fx-text-fill: #888;"/>
        </placeholder>

    </TableView>
    <HBox spacing="12"
          alignment="CENTER_RIGHT"
          style="-fx-padding: 10 0 0 0;">

        <Button text="🚪 Checkout"
                onAction="#handleCheckout"
                style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>
    </HBox>
</VBox>