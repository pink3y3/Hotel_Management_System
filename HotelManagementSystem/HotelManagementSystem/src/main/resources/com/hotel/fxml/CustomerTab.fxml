<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  CustomerTab.fxml  —  Customers tab content
  Controller: CustomerController

  KEY FEATURE: DatePicker (fx:id="dobPicker") for Date of Birth selection.
  Validation is handled in CustomerController.handleAddCustomer():
    - DOB must not be null
    - DOB must not be in the future
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.controller.CustomerController"
      styleClass="tab-content" spacing="16">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <!-- ── Add Customer Form ─────────────────────────────────────── -->
    <VBox styleClass="card" spacing="14">
        <Label text="Add New Customer" styleClass="card-title"/>

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="130" prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="130" prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 0 -->
            <Label text="Full Name" styleClass="field-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="customerNameField" promptText="e.g. John Smith"
                       styleClass="text-field-styled"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Contact Number" styleClass="field-label"
                   GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="contactNumberField" promptText="e.g. 9876543210"
                       styleClass="text-field-styled"
                       GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <!-- Row 1 -->
            <!--
              DatePicker for Date of Birth
              ─────────────────────────────
              JavaFX DatePicker provides a calendar pop-up.
              The selected value is retrieved as a LocalDate via .getValue().

              Validation in controller:
                • null check  → "Please fill in all customer fields."
                • future date → "Date of birth cannot be in the future."
            -->
            <Label text="Date of Birth" styleClass="field-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="dobPicker"
                        promptText="Select date of birth"
                        maxWidth="Infinity"
                        styleClass="date-picker-styled"
                        GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="➕  Add Customer" onAction="#handleAddCustomer" styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- ── Search bar ────────────────────────────────────────────── -->
    <HBox styleClass="toolbar" spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchCustomerField" promptText="Search by name or ID…"
                   prefWidth="260" styleClass="text-field-styled"/>
        <Button text="🔍 Search"      onAction="#handleSearch"      styleClass="btn-secondary"/>
        <Button text="✕ Clear Search" onAction="#handleClearSearch" styleClass="btn-ghost"/>
    </HBox>

    <!-- ── Customer Table ────────────────────────────────────────── -->
    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS" styleClass="table-styled">
        <columns>
            <TableColumn fx:id="colCustomerId"   text="Customer ID" prefWidth="120"/>
            <TableColumn fx:id="colCustomerName" text="Name"        prefWidth="200"/>
            <TableColumn fx:id="colContact"      text="Contact"     prefWidth="150"/>
            <TableColumn fx:id="colDob"          text="Date of Birth" prefWidth="140"/>
        </columns>
        <placeholder><Label text="No customers found." styleClass="table-placeholder"/></placeholder>
    </TableView>
</VBox>
