<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.BillingController"
      style="-fx-background-color: #121212; -fx-padding: 24;">

    <!-- ── Select Booking ───────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Select Booking:"
               style="-fx-text-fill: white;"/>

        <ComboBox fx:id="billingBookingCombo"
                  prefWidth="260"
                  style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"/>

        <Button text="↺ Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color: transparent; -fx-border-color: #c6a75e; -fx-text-fill: #c6a75e;"/>
    </HBox>

    <!-- ── Main Content ───────────────────────── -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- Left: Bill Details -->
        <VBox spacing="16" prefWidth="420"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">

            <Label text="Bill Details"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

            <GridPane hgap="14" vgap="10">

                <columnConstraints>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Booking ID" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="0"/>
                <Label fx:id="bookingIdLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Customer" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="1"/>
                <Label fx:id="customerLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Room" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="2"/>
                <Label fx:id="roomLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Nights" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="3"/>
                <Label fx:id="nightsLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Separator GridPane.columnSpan="2" GridPane.rowIndex="4"/>

                <Label text="Room Charges (₹)" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="5"/>
                <Label fx:id="roomChargesLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Package Cost (₹)" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="6"/>
                <Label fx:id="packageCostLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                <Label text="Sub-Total (₹)" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="7"/>
                <Label fx:id="subTotalLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

                <Label text="Discount" style="-fx-text-fill: #cccccc;" GridPane.rowIndex="8"/>
                <Label fx:id="discountLabel" text="—" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                <Separator GridPane.columnSpan="2" GridPane.rowIndex="9"/>

                <Label text="TOTAL PAYABLE (₹)"
                       style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"
                       GridPane.rowIndex="10"/>

                <Label fx:id="finalBillLabel"
                       text="—"
                       style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="10"/>

            </GridPane>

            <Label fx:id="birthdayNoteLabel"
                   text=""
                   style="-fx-text-fill: #c6a75e;"/>

            <Separator/>

            <!-- Actions -->
            <HBox spacing="12">
                <Button text="🖨 Print Bill"
                        onAction="#handlePrintBill"
                        style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>

                <Button text="📧 Send E-Bill"
                        fx:id="sendEmailButton"
                        onAction="#handleSendEmail"
                        style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>
            </HBox>

            <Label fx:id="emailStatusLabel"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #aaaaaa;"/>
        </VBox>

        <!-- Right: Preview -->
        <VBox spacing="10"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">

            <Label text="Bill Preview"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TextArea fx:id="billTextArea"
                      editable="false"
                      wrapText="true"
                      VBox.vgrow="ALWAYS"
                      promptText="Select a booking to preview the bill…"
                      style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: white;"/>
        </VBox>

    </HBox>

</VBox>