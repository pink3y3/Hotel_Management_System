<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="tab-content" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.hotel.controller.BillingController">

    <padding>
        <Insets bottom="24" left="24" right="24" top="24" />
    </padding>

    <!-- ── Select Booking ───────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
        <Label styleClass="field-label" text="Select Booking:" />
        <ComboBox fx:id="billingBookingCombo" prefWidth="260" style="-fx-background-color: #C6A75EFF;" styleClass="combo-styled" />
        <Button onAction="#handleRefresh" style="-fx-background-color: #C6A75EFF;" styleClass="btn-ghost" text="↺ Refresh" textFill="WHITE" />
    </HBox>

    <!-- ── Main Content ───────────────────────── -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- Left: Bill Details -->
        <VBox prefWidth="420" spacing="14" styleClass="card">

            <Label styleClass="card-title" text="Bill Details" />

            <GridPane hgap="14" vgap="10">
                <columnConstraints>
                    <ColumnConstraints prefWidth="150" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label styleClass="bill-label" text="Booking ID" GridPane.rowIndex="0" />
                <Label fx:id="bookingIdLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label styleClass="bill-label" text="Customer" GridPane.rowIndex="1" />
                <Label fx:id="customerLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="bill-label" text="Room" GridPane.rowIndex="2" />
                <Label fx:id="roomLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label styleClass="bill-label" text="Nights" GridPane.rowIndex="3" />
                <Label fx:id="nightsLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Separator GridPane.columnSpan="2" GridPane.rowIndex="4" />

                <Label styleClass="bill-label" text="Room Charges (₹)" GridPane.rowIndex="5" />
                <Label fx:id="roomChargesLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label styleClass="bill-label" text="Package Cost (₹)" GridPane.rowIndex="6" />
                <Label fx:id="packageCostLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label styleClass="bill-label" text="Sub-Total (₹)" GridPane.rowIndex="7" />
                <Label fx:id="subTotalLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <Label styleClass="bill-label" text="Discount" GridPane.rowIndex="8" />
                <Label fx:id="discountLabel" styleClass="bill-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <Separator GridPane.columnSpan="2" GridPane.rowIndex="9" />

                <Label styleClass="bill-total-label" text="TOTAL PAYABLE (₹)" GridPane.rowIndex="10" />
                <Label fx:id="finalBillLabel" styleClass="bill-total-value" text="—" GridPane.columnIndex="1" GridPane.rowIndex="10" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <Label fx:id="birthdayNoteLabel" styleClass="birthday-label" text="" />

            <Separator />

            <!-- Actions -->
            <HBox spacing="10">
                <Button onAction="#handlePrintBill" style="-fx-background-color: #C6A75EFF;" styleClass="btn-secondary" text="🖨 Print Bill" textFill="WHITE" />
                <Button fx:id="sendEmailButton" onAction="#handleSendEmail" style="-fx-background-color: #C6A75EFF;" styleClass="btn-primary" text="📧 Send E-Bill" textFill="WHITE" />
            </HBox>

            <Label fx:id="emailStatusLabel" styleClass="status-label" text="" wrapText="true" />
        </VBox>

        <!-- Right: Preview -->
        <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="card-title" text="Bill Preview" />

            <TextArea fx:id="billTextArea" editable="false" promptText="Select a booking to preview the bill…" styleClass="bill-textarea" wrapText="true" VBox.vgrow="ALWAYS" />
        </VBox>

    </HBox>

</VBox>
