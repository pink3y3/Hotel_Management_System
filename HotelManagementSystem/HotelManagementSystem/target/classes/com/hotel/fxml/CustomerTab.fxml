<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  CustomerTab.fxml  —  Customers tab content
  Controller: CustomerController

  KEY FEATURE: DatePicker (fx:id="dobPicker") for Date of Birth selection.
  Validation is handled in CustomerController.handleAddCustomer():
    - DOB must not be null
    - DOB must not be in the future
-->

<VBox spacing="16" styleClass="tab-content" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.hotel.controller.CustomerController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <!-- ── Add Customer Form ─────────────────────────────────────── -->
    <VBox spacing="14" styleClass="card">
        <Label styleClass="card-title" text="Add New Customer" />

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="130" prefWidth="150" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints minWidth="130" prefWidth="150" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <!-- Row 0 -->
            <Label styleClass="field-label" text="Full Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="customerNameField" promptText="e.g. Rahul Sharma" styleClass="text-field-styled" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="field-label" text="Contact Number" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="contactNumberField" promptText="e.g. 9876543210" styleClass="text-field-styled" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <!-- Row 1 -->
            <Label styleClass="field-label" text="Date of Birth" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <DatePicker fx:id="dobPicker" maxWidth="Infinity" promptText="Select date of birth" styleClass="date-picker-styled" GridPane.columnIndex="1" GridPane.rowIndex="1" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <HBox spacing="10">
            <Button onAction="#handleAddCustomer" style="-fx-background-color: #C6A75EFF;" styleClass="btn-primary" text="➕  Add Customer" textFill="WHITE" />
        </HBox>
    </VBox>

    <!-- ── Search bar ────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
        <TextField fx:id="searchCustomerField" prefWidth="260" promptText="Search by name or ID…" styleClass="text-field-styled" />
        <Button onAction="#handleSearch" style="-fx-background-color: #C6A75EFF;" styleClass="btn-secondary" text="🔍 Search" textFill="WHITE" />
        <Button onAction="#handleClearSearch" style="-fx-background-color: #C6A75EFF;" styleClass="btn-ghost" text="✕ Clear Search" textFill="WHITE" />
    </HBox>

    <!-- ── Customer Table ────────────────────────────────────────── -->
    <TableView fx:id="customerTable" styleClass="table-styled" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCustomerId" prefWidth="120" text="Customer ID" />
            <TableColumn fx:id="colCustomerName" prefWidth="200" text="Name" />
            <TableColumn fx:id="colContact" prefWidth="150" text="Contact" />
            <TableColumn fx:id="colDob" prefWidth="140" text="Date of Birth" />
        </columns>
        <placeholder><Label styleClass="table-placeholder" text="No customers found." /></placeholder>
    </TableView>
</VBox>
