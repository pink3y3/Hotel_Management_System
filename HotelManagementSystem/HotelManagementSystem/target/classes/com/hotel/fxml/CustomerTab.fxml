<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.CustomerController"
      style="-fx-background-color: #121212; -fx-padding: 24;">

    <!-- ── Add Customer ───────────────────────── -->
    <VBox spacing="16"
          style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">

        <Label text="Add New Customer"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <GridPane hgap="16" vgap="12">

            <columnConstraints>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 0 -->
            <Label text="Full Name"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="0"/>

            <TextField fx:id="customerNameField"
                       promptText="e.g. Rahul Sharma"
                       style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0"/>

            <Label text="Contact Number"
                   style="-fx-text-fill: white;"
                   GridPane.columnIndex="2"
                   GridPane.rowIndex="0"/>

            <TextField fx:id="contactNumberField"
                       promptText="e.g. 9876543210"
                       style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                       GridPane.columnIndex="3"
                       GridPane.rowIndex="0"/>

            <!-- Row 1 -->
            <Label text="Date of Birth"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="1"/>

            <DatePicker fx:id="dobPicker"
                        maxWidth="Infinity"
                        promptText="Select date of birth"
                        style="-fx-background-color: #1e1e1e;"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="1"/>

        </GridPane>

        <HBox spacing="12">
            <Button text="➕ Add Customer"
                    onAction="#handleAddCustomer"
                    style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>
        </HBox>

    </VBox>

    <!-- ── Search ───────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT">

        <TextField fx:id="searchCustomerField"
                   prefWidth="260"
                   promptText="Search by name or ID…"
                   style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"/>

        <Button text="🔍 Search"
                onAction="#handleSearch"
                style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>

        <Button text="✕ Clear Search"
                onAction="#handleClearSearch"
                style="-fx-background-color: transparent; -fx-border-color: #c6a75e; -fx-text-fill: #c6a75e;"/>
    </HBox>

    <!-- ── Table ───────────────────────── -->
    <TableView fx:id="customerTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #1c1c1c;">

        <columns>
            <TableColumn fx:id="colCustomerId" text="Customer ID"/>
            <TableColumn fx:id="colCustomerName" text="Name"/>
            <TableColumn fx:id="colContact" text="Contact"/>
            <TableColumn fx:id="colDob" text="Date of Birth"/>
        </columns>

        <placeholder>
            <Label text="No customers found."
                   style="-fx-text-fill: #888;"/>
        </placeholder>

    </TableView>

</VBox>