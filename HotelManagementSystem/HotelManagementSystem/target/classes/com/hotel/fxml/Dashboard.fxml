<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-font-family: 'Georgia'; -fx-font-size: 13px;" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.DashboardController">

    <!-- ── Top header bar ───────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #333333FF;" styleClass="dashboard-header">
            <padding>
                <Insets bottom="16" left="32" right="32" top="16" />
            </padding>

            <!-- Icon -->
            <Label styleClass="header-icon" text="♞" textFill="WHITE">
            <font>
               <Font size="25.0" />
            </font></Label>

            <!-- Title block -->
            <VBox spacing="2">
                <Label styleClass="header-title" text="THE STANLEY HOTEL" textFill="WHITE" />
                <Label styleClass="header-sub" text="Management System" textFill="WHITE" />
            </VBox>
        </HBox>
    </top>

    <!-- ── Tab pane ─────────────────────────────────────────────── -->
    <center>
        <TabPane fx:id="mainTabPane" style="-fx-background-color: #ffffff;" styleClass="main-tab-pane" tabClosingPolicy="UNAVAILABLE">

            <!-- Rooms -->
            <Tab style="fx-backgroun-color: #C6A75EFF;" text="🛏 Rooms">
                <fx:include fx:id="roomTab" source="RoomTab.fxml" />
            </Tab>

            <!-- Customers -->
            <Tab style="fx-background-color: #C6A75EFF;" text="👤 Customers">
                <fx:include fx:id="customerTab" source="CustomerTab.fxml" />
            </Tab>

            <!-- Booking -->
            <Tab text="📋 Booking">
                <fx:include fx:id="bookingTab" source="BookingTab.fxml" />
            </Tab>

            <!-- Packages -->
            <Tab text="🎁 Packages">
                <fx:include fx:id="packageTab" source="PackageTab.fxml" />
            </Tab>

            <!-- Billing -->
            <Tab text="💳 Billing">
                <fx:include fx:id="billingTab" source="BillingTab.fxml" />
            </Tab>

        </TabPane>
    </center>

</BorderPane>
