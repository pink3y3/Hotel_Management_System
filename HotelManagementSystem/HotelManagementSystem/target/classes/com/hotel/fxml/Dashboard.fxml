<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.controller.DashboardController"
            style="-fx-background-color: #121212; -fx-font-family: 'Georgia'; -fx-font-size: 13px;">

    <!-- ── Top Header ───────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="16"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16 32 16 32;">

            <!-- Icon -->
            <Label text="♞"
                   style="-fx-text-fill: #c6a75e; -fx-font-size: 24px;"/>

            <!-- Title -->
            <VBox spacing="2">
                <Label text="THE STANLEY HOTEL"
                       style="-fx-text-fill: #c6a75e; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Management System"
                       style="-fx-text-fill: #cccccc; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>
    </top>

    <!-- ── Tabs ───────────────────────── -->
    <center>
        <TabPane fx:id="mainTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #121212;">

            <tabs>

                <Tab text="🛏 Rooms"
                     style="-fx-background-color: #1c1c1c; -fx-text-base-color: white;">
                    <fx:include fx:id="roomTab" source="RoomTab.fxml"/>
                </Tab>

                <Tab text="👤 Customers"
                     style="-fx-background-color: #1c1c1c; -fx-text-base-color: white;">
                    <fx:include fx:id="customerTab" source="CustomerTab.fxml"/>
                </Tab>

                <Tab text="📋 Booking"
                     style="-fx-background-color: #1c1c1c; -fx-text-base-color: white;">
                    <fx:include fx:id="bookingTab" source="BookingTab.fxml"/>
                </Tab>

                <Tab text="🎁 Packages"
                     style="-fx-background-color: #1c1c1c; -fx-text-base-color: white;">
                    <fx:include fx:id="packageTab" source="PackageTab.fxml"/>
                </Tab>

                <Tab text="💳 Billing"
                     style="-fx-background-color: #1c1c1c; -fx-text-base-color: white;">
                    <fx:include fx:id="billingTab" source="BillingTab.fxml"/>
                </Tab>

            </tabs>
        </TabPane>
    </center>

</BorderPane>