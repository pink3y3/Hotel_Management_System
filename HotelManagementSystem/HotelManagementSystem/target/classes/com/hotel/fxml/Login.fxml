<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="0" styleClass="login-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controller.LoginController">

    <!-- Header banner -->
    <VBox alignment="CENTER" prefHeight="102.0" prefWidth="350.0" spacing="4" styleClass="login-header">
        <Label styleClass="login-hotel-icon" text="♞" textFill="#d4a843">
         <font>
            <Font size="23.0" />
         </font></Label>
        <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="17.0" prefWidth="200.0" styleClass="login-title" text=" THE STANLEY HOTEL" textFill="#d4a843">
            <font>
                <Font name="Georgia" size="14.0" />
            </font></Label>
        <Label alignment="CENTER" prefHeight="16.0" prefWidth="140.0" styleClass="login-subtitle" text="Management System" textFill="#b0b8c8">
            <font>
                <Font name="Georgia" size="12.0" />
            </font></Label>
    </VBox>

    <!-- Card -->
    <VBox alignment="CENTER" spacing="18" style="-fx-background-color: #000000;" styleClass="login-card">
        <padding><Insets bottom="36" left="44" right="44" top="36" /></padding>

        <Label styleClass="login-card-title" text="Admin Login" textFill="WHITE">
            <font>
                <Font name="Georgia" size="14.0" />
            </font></Label>

        <VBox spacing="6">
            <Label styleClass="field-label" text="Username" textFill="WHITE">
                <font>
                    <Font name="Georgia" size="12.0" />
                </font></Label>
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-field-styled" />
        </VBox>

        <VBox spacing="6">
            <Label styleClass="field-label" text="Password" textFill="WHITE">
                <font>
                    <Font name="Georgia" size="12.0" />
                </font></Label>
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-field-styled" />
        </VBox>

        <HBox alignment="CENTER" spacing="12">
            <Button defaultButton="true" onAction="#handleLogin" prefWidth="141.0" styleClass="btn-primary" text="Login" textFill="WHITE" />
            <Button onAction="#handleClear" prefWidth="110" styleClass="btn-secondary" text="Clear" />
        </HBox>

        <Label styleClass="login-hint" text="Default: admin / hotel123" />
    </VBox>

</VBox>
