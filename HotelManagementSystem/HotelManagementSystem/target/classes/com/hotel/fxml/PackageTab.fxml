<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.controller.PackageController"
      style="-fx-background-color: #121212; -fx-padding: 24;">

    <!-- Title -->
    <Label text="Available Packages"
           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Package Cards -->
    <HBox spacing="20">

        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">
            <Label text="🌿 BASIC"
                   style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"/>
            <Label fx:id="basicDescLabel"
                   wrapText="true"
                   style="-fx-text-fill: white;"/>
            <Label fx:id="basicCostLabel"
                   style="-fx-text-fill: #c6a75e;"/>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">
            <Label text="⭐ PREMIUM"
                   style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"/>
            <Label fx:id="premiumDescLabel"
                   wrapText="true"
                   style="-fx-text-fill: white;"/>
            <Label fx:id="premiumCostLabel"
                   style="-fx-text-fill: #c6a75e;"/>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">
            <Label text="💎 LUXURY"
                   style="-fx-text-fill: #c6a75e; -fx-font-weight: bold;"/>
            <Label fx:id="luxuryDescLabel"
                   wrapText="true"
                   style="-fx-text-fill: white;"/>
            <Label fx:id="luxuryCostLabel"
                   style="-fx-text-fill: #c6a75e;"/>
        </VBox>

    </HBox>

    <!-- Assign Section -->
    <VBox spacing="16"
          style="-fx-background-color: #1c1c1c; -fx-padding: 16; -fx-border-color: #333;">

        <Label text="Assign Package to Booking"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <GridPane hgap="16" vgap="12">

            <columnConstraints>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints prefWidth="150"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Select Booking"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="0"/>

            <ComboBox fx:id="bookingCombo"
                      maxWidth="Infinity"
                      style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0"/>

            <Label text="Package Type"
                   style="-fx-text-fill: white;"
                   GridPane.columnIndex="2"
                   GridPane.rowIndex="0"/>

            <ComboBox fx:id="packageTypeCombo"
                      maxWidth="Infinity"
                      style="-fx-background-color: #1e1e1e; -fx-text-fill: white;"
                      GridPane.columnIndex="3"
                      GridPane.rowIndex="0"/>

            <Label text="Description"
                   style="-fx-text-fill: white;"
                   GridPane.rowIndex="1"/>

            <Label fx:id="packageDescLabel"
                   wrapText="true"
                   style="-fx-text-fill: white;"
                   GridPane.columnIndex="1"
                   GridPane.columnSpan="2"
                   GridPane.rowIndex="1"/>

            <Label fx:id="packageCostLabel"
                   style="-fx-text-fill: #c6a75e;"
                   GridPane.columnIndex="3"
                   GridPane.rowIndex="1"/>

        </GridPane>

        <HBox spacing="12">
            <Button text="✅ Assign Package"
                    onAction="#handleAssignPackage"
                    style="-fx-background-color: #c6a75e; -fx-text-fill: black;"/>

            <Button text="↺ Refresh"
                    onAction="#handleRefresh"
                    style="-fx-background-color: transparent; -fx-border-color: #c6a75e; -fx-text-fill: #c6a75e;"/>
        </HBox>

    </VBox>

    <!-- Table -->
    <Label text="Package Assignment History"
           style="-fx-text-fill: white; -fx-font-size: 16px;"/>

    <TableView fx:id="assignTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #1c1c1c;">

        <columns>
            <TableColumn fx:id="colAssignBookingId" text="Booking ID"/>
            <TableColumn fx:id="colAssignCustomer" text="Customer"/>
            <TableColumn fx:id="colAssignRoom" text="Room"/>
            <TableColumn fx:id="colAssignPackage" text="Package"/>
        </columns>

        <placeholder>
            <Label text="No package assignments yet."
                   style="-fx-text-fill: #888;"/>
        </placeholder>

    </TableView>

</VBox>