<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  RoomTab.fxml  —  Rooms tab content
  Controller: RoomController (injected by fx:include in Dashboard.fxml)
-->

<VBox spacing="16" styleClass="tab-content" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.hotel.controller.RoomController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <!-- ── Add Room Form ─────────────────────────────────────────── -->
    <VBox spacing="14" styleClass="card">
        <Label styleClass="card-title" text="Add New Room" />

        <GridPane hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="140" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints minWidth="120" prefWidth="140" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <!-- Row 0 -->
            <Label styleClass="field-label" text="Room Number" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="roomNumberField" promptText="e.g. 101" styleClass="text-field-styled" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="field-label" text="Room Type" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <ComboBox fx:id="roomTypeCombo" maxWidth="Infinity" style="-fx-background-color: #C6A75EFF;" styleClass="combo-styled" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <!-- Row 1 -->
            <Label styleClass="field-label" text="Price / Night (₹)" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="priceField" promptText="e.g. 5000.00" styleClass="text-field-styled" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="field-label" text="Available" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <CheckBox fx:id="availableCheckBox" selected="true" GridPane.columnIndex="3" GridPane.rowIndex="1" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <HBox spacing="10">
            <Button onAction="#handleAddRoom" style="-fx-background-color: #C6A75EFF;" styleClass="btn-primary" text="➕  Add Room" textFill="WHITE" />
        </HBox>
    </VBox>

    <!-- ── Filter / Search bar ───────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
        <CheckBox fx:id="filterAvailableCheckBox" onAction="#handleFilter" styleClass="check-toolbar" text="Show Available Only" />
        <TextField fx:id="searchRoomField" prefWidth="220" promptText="Search room number or type…" styleClass="text-field-styled" />
        <Button onAction="#handleSearch" style="-fx-background-color: #C6A75EFF;" styleClass="btn-secondary" text="🔍 Search" textFill="WHITE" />
        <Button onAction="#handleRefresh" style="-fx-background-color: #C6A75EFF;" styleClass="btn-ghost" text="↺ Refresh" textFill="WHITE" />
    </HBox>

    <!-- ── Room Table ─────────────────────────────────────────────── -->
    <TableView fx:id="roomTable" styleClass="table-styled" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colRoomNumber" prefWidth="100" text="Room #" />
            <TableColumn fx:id="colRoomType" prefWidth="120" text="Type" />
            <TableColumn fx:id="colPrice" prefWidth="140" text="Price/Night (₹)" />
            <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
        </columns>
        <placeholder><Label styleClass="table-placeholder" text="No rooms found." /></placeholder>
    </TableView>
</VBox>
